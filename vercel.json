{
  "version": 2,
  "name": "rubeninvestor-elite",
  "rewrites": [
    { "source": "/api/quotes", "destination": "/api/quotes" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "s-maxage=60" }
      ]
    }
  ]
}
